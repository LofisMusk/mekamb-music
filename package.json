{
  "name": "mekamb-music-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop client for Mekamb Music.",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "vite build --configLoader runner",
    "desktop": "npm run build && electron .",
    "desktop:dist": "npm run build && electron-builder",
    "desktop:dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "desktop:dist:mac": "npm run build && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "tailwindcss": "4.1.12",
    "tw-animate-css": "1.3.8",
    "vite": "6.3.5"
  },
  "build": {
    "appId": "pl.mekamb.music",
    "productName": "Mekamb Music",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop/**/*",
      "client-dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Audio;Music;Player",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
