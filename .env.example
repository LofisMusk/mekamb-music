APP_NAME="Mekamb Music"
ENVIRONMENT=local
API_TOKEN=change-me-to-a-long-random-token
INSTANCE_ID=local

PERSONAL_1337X_BASE_URL=https://1337x.to
PERSONAL_1337X_MAX_PAGES=1

PIRATEBAY_API_BASE_URL=https://apibay.org
PIRATEBAY_CATEGORY=100

DATABASE_URL=postgresql+asyncpg://music:music@postgres:5432/music
REDIS_URL=redis://redis:6379/0
IMPORT_QUEUE_NAME=mekamb-music:import-events

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=miniosecret
S3_BUCKET=music-library
S3_REGION=us-east-1
STORAGE_BACKEND=s3

QUARANTINE_ROOT=/data/quarantine
LIBRARY_ROOT=/data/library
TORRENT_DOWNLOAD_ROOT=/downloads/incomplete
TORRENT_RPC_URL=http://qbittorrent:8080
TORRENT_RPC_USERNAME=admin
TORRENT_RPC_PASSWORD=adminadmin
TORRENT_LISTEN_PORT=6881
IMPORT_WORKER_INTERVAL_SECONDS=15
CLEANUP_QUARANTINE_AFTER_IMPORT=true
REMOVE_TORRENT_AFTER_IMPORT=true
PLAYBACK_PREFETCH_COUNT=2
