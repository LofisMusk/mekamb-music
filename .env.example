APP_NAME="Mekamb Music"
ENVIRONMENT=local
API_TOKEN=change-me-to-a-long-random-token
# Optional: multiple named bearer tokens. Each gets separate personal data
# while sharing the downloaded library. Example:
# API_TOKENS=alice:change-me-one,bob:change-me-two
API_TOKENS=
INSTANCE_ID=local

PERSONAL_1337X_BASE_URL=https://1337x.to
PERSONAL_1337X_MAX_PAGES=1

PIRATEBAY_API_BASE_URL=https://apibay.org
PIRATEBAY_CATEGORY=100

# Optional Torznab/Prowlarr music indexers used by the iOS "Indexers" search mode.
# Preferred: query Prowlarr directly across all configured indexers.
MUSIC_INDEXER_PROWLARR_URL=http://prowlarr:9696
MUSIC_INDEXER_API_KEY=
# Optional fallback: one or more raw Torznab URLs, separated by commas/newlines.
MUSIC_INDEXER_TORZNAB_URLS=
MUSIC_INDEXER_CATEGORIES=3000

DATABASE_URL=postgresql+asyncpg://music:music@postgres:5432/music
REDIS_URL=redis://redis:6379/0
IMPORT_QUEUE_NAME=mekamb-music:import-events

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=miniosecret
S3_BUCKET=music-library
S3_REGION=us-east-1
STORAGE_BACKEND=s3

QUARANTINE_ROOT=/data/quarantine
LIBRARY_ROOT=/data/library
TORRENT_DOWNLOAD_ROOT=/downloads/incomplete
TORRENT_RPC_URL=http://qbittorrent:8080
TORRENT_RPC_USERNAME=admin
TORRENT_RPC_PASSWORD=adminadmin
TORRENT_LISTEN_PORT=6881
IMPORT_WORKER_INTERVAL_SECONDS=15
CLEANUP_QUARANTINE_AFTER_IMPORT=true
REMOVE_TORRENT_AFTER_IMPORT=true
PLAYBACK_PREFETCH_COUNT=2
RECOMMENDATION_SOURCES=indexer
RECOMMENDATION_AUTO_IMPORT_LIMIT=3
RECOMMENDATION_MIN_SEEDERS=1
