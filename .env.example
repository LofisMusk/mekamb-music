APP_NAME="Mekamb Music"
ENVIRONMENT=local
API_TOKEN=change-me-to-a-long-random-token
# Optional: multiple named bearer tokens. Each gets separate personal data
# while sharing the downloaded library. Example:
# API_TOKENS=alice:change-me-one,bob:change-me-two
# These legacy tokens keep authenticating in parallel with the new account
# system, and existing users can migrate them via "I have a token" (claim-token).
API_TOKENS=
INSTANCE_ID=local

# ── Accounts / authentication ────────────────────────────────────────────────
# Email/username/password accounts. New signups are `pending` and cannot log in
# until an admin approves them. Emails listed here are bootstrapped as approved
# admins on register/claim so the first admin can get in (comma-separated).
ADMIN_EMAILS=
REGISTRATION_ENABLED=true
AUTH_SESSION_TTL_DAYS=90
PASSWORD_MIN_LENGTH=8
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SECONDS=300

# ── Lidarr (music acquisition + organization) ─────────────────────────────────
# Lidarr owns discovery, monitoring, and downloading (via its own Prowlarr +
# download client) and writes organized albums into LIDARR_ROOT_FOLDER, which the
# backend also mounts so it can ingest finished albums. Configure Lidarr's
# Connect → Webhook to POST http://api:8000/catalog/webhook?token=<LIDARR_WEBHOOK_TOKEN>.
LIDARR_ENABLED=true
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=
LIDARR_ROOT_FOLDER=/data/library-source
LIDARR_QUALITY_PROFILE_ID=1
LIDARR_METADATA_PROFILE_ID=1
LIDARR_WEBHOOK_TOKEN=change-me-to-a-long-random-token
# copy | hardlink — hardlink avoids duplicating large lossless files when the
# Lidarr root folder and quarantine share a filesystem.
LIDARR_INGEST_STRATEGY=copy

DATABASE_URL=postgresql+asyncpg://music:music@postgres:5432/music
REDIS_URL=redis://redis:6379/0
IMPORT_QUEUE_NAME=mekamb-music:import-events

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=miniosecret
S3_BUCKET=music-library
S3_REGION=us-east-1
STORAGE_BACKEND=s3

QUARANTINE_ROOT=/data/quarantine
LIBRARY_ROOT=/data/library
IMPORT_WORKER_INTERVAL_SECONDS=15
CLEANUP_QUARANTINE_AFTER_IMPORT=true
PLAYBACK_PREFETCH_COUNT=2
RECOMMENDATION_USE_GEMINI=true
RECOMMENDATION_GEMINI_CANDIDATE_LIMIT=24
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=8
